rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function validImage() {
      return request.resource != null
        && request.resource.size > 0
        && request.resource.size <= 8 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|webp|gif)');
    }

    function validFileName(fileName) {
      return fileName.matches('^[A-Za-z0-9._-]{1,180}$');
    }

    match /feeds/{userId}/{fileName} {
      allow read: if true;
      allow create, update: if isOwner(userId) && validFileName(fileName) && validImage();
      allow delete: if isOwner(userId);
    }

    match /community/materials/{userId}/{fileName} {
      allow read: if true;
      allow create, update: if isOwner(userId) && validFileName(fileName) && validImage();
      allow delete: if isOwner(userId);
    }

    match /community/debates/{userId}/{fileName} {
      allow read: if true;
      allow create, update: if isOwner(userId) && validFileName(fileName) && validImage();
      allow delete: if isOwner(userId);
    }

    match /soso-feed/{userId}/{fileName} {
      allow read: if true;
      allow write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
