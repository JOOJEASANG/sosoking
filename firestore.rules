rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function publicResult(caseId) {
      return exists(/databases/$(database)/documents/results/$(caseId))
        && get(/databases/$(database)/documents/results/$(caseId)).data.isPublic == true;
    }

    match /cases/{caseId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /results/{caseId} {
      allow read: if resource.data.isPublic == true
        || (signedIn() && resource.data.userId == request.auth.uid);
      allow create, update, delete: if false;
    }

    match /result_reactions/{caseId} {
      allow read: if publicResult(caseId);
      allow create, update, delete: if false;

      match /votes/{userId} {
        allow read: if signedIn() && request.auth.uid == userId && publicResult(caseId);
        allow create, update, delete: if false;
      }
    }

    match /court_comments/{caseId}/items/{commentId} {
      allow read: if publicResult(caseId);
      allow create, update, delete: if false;
    }

    match /rate_limits/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create, update, delete: if false;
    }

    match /comment_limits/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create, update, delete: if false;
    }

    match /reports/{reportId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
