rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn()  { return request.auth != null; }
    function isAuthor(uid) { return signedIn() && request.auth.uid == uid; }
    function isAdmin()   {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    function isGameHost(roomId) {
      return signedIn()
        && get(/databases/$(database)/documents/game_rooms/$(roomId)).data.hostId == request.auth.uid;
    }
    function isGameRoomPlayer(roomId) {
      return signedIn()
        && exists(/databases/$(database)/documents/game_rooms/$(roomId)/players/$(request.auth.uid));
    }

    function validText(val, maxLen) {
      return val is string && val.size() <= maxLen;
    }
    function validNickname(nick) {
      return nick is string && nick.size() >= 2 && nick.size() <= 12
        && nick.matches('^[가-힣a-zA-Z0-9_]+$');
    }
    function validImageList() {
      return !('images' in request.resource.data)
        || (request.resource.data.images is list && request.resource.data.images.size() <= 20);
    }
    function validInitialCounter(field) {
      return !(field in request.resource.data) || request.resource.data[field] == 0;
    }
    function validInitialReactions() {
      return !('reactions' in request.resource.data)
        || (request.resource.data.reactions is map
          && request.resource.data.reactions.get('total', 0) == 0);
    }
    function validFeedCreateShape() {
      return request.resource.data.keys().hasOnly([
          'type', 'cat', 'subtype', 'feedType', 'typeLabel',
          'title', 'desc', 'body', 'subtitle', 'tags', 'images', 'modules',
          'anonymous', 'anonymousMode', 'authorId', 'authorName', 'authorPhoto', 'authorEmail',
          'reactions', 'commentCount', 'acrosticCount', 'viewCount', 'pointsScore',
          'options', 'initials', 'hint', 'keyword', 'evidence',
          'startSentence', 'characters', 'charCount', 'deadline', 'deadlineAt', 'createdAt', 'updatedAt'
        ])
        && !request.resource.data.keys().hasAny(['hidden', 'hideReason', 'votedBy', 'reactedWith'])
        && validInitialCounter('commentCount')
        && validInitialCounter('acrosticCount')
        && validInitialCounter('viewCount')
        && validInitialCounter('pointsScore')
        && validInitialReactions();
    }
    function isSafeCounterUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return signedIn()
        && changed.hasOnly(['commentCount'])
        && (
          request.resource.data.commentCount == resource.data.get('commentCount', 0) + 1 ||
          request.resource.data.commentCount == resource.data.get('commentCount', 0) - 1
        );
    }

    function isSafeVoteUpdate() { return false; }
    function isSafeMultiVoteUpdate() { return false; }
    function isAuthorContentUpdate(authorId) {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return isAuthor(authorId)
        && request.resource.data.authorId == resource.data.authorId
        && !changed.hasAny([
          'authorId', 'authorName', 'authorPhoto', 'authorEmail',
          'reactions', 'reactedWith', 'commentCount', 'acrosticCount',
          'viewCount', 'votedBy', 'pointsScore',
          'options', 'modules',
          'hidden', 'hideReason'
        ]);
    }
    function isMultiItemReactionOrReplyCountUpdate() { return false; }
    function validReplyCreate() { return false; }
    function validMultiParticipationCreate() { return false; }
    function validUserSelfUpdate(userId) {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return isAuthor(userId)
        && changed.hasOnly(['nicknameIcon', 'updatedAt'])
        && (!('nicknameIcon' in request.resource.data)
          || request.resource.data.nicknameIcon == null
          || request.resource.data.nicknameIcon is map);
    }
    function validNotificationReadUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return signedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == resource.data.uid
        && changed.hasOnly(['read', 'readAt', 'readAtMs'])
        && request.resource.data.read == true
        && (!('readAtMs' in request.resource.data) || request.resource.data.readAtMs is number)
        && (!('readAt' in request.resource.data) || request.resource.data.readAt is timestamp);
    }

    match /admins/{uid} {
      allow read:  if signedIn() && request.auth.uid == uid;
      allow write: if false;
    }

    match /site_settings/{docId}  { allow read: if true; allow write: if isAdmin(); }
    match /policy_docs/{docId}    { allow read: if true; allow write: if isAdmin(); }
    match /admin_summaries/{docId} { allow read: if isAdmin(); allow write: if false; }
    match /ai_usage/{docId}        { allow read: if isAdmin(); allow write: if false; }

    match /users/{userId} {
      allow read:   if isAuthor(userId) || isAdmin();
      allow create: if isAuthor(userId)
                      && validNickname(request.resource.data.get('nickname', ''));
      allow update: if isAdmin() || validUserSelfUpdate(userId);
      allow delete: if isAdmin();

      match /point_logs/{logId} {
        allow read: if isAuthor(userId) || isAdmin();
        allow create, update, delete: if false;
      }
      match /scraps/{scrapId} {
        allow read:   if isAuthor(userId) || isAdmin();
        allow create: if isAuthor(userId) && request.resource.data.postId is string;
        allow delete: if isAuthor(userId) || isAdmin();
        allow update: if false;
      }
    }

    match /nicknames/{nickname} {
      allow read:   if signedIn();
      allow create: if signedIn()
                      && validNickname(nickname)
                      && request.resource.data.uid == request.auth.uid
                      && !exists(/databases/$(database)/documents/nicknames/$(nickname));
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    match /feeds/{postId} {
      allow read:   if true;
      allow create: if signedIn()
                      && validFeedCreateShape()
                      && request.resource.data.authorId == request.auth.uid
                      && validText(request.resource.data.title, 100)
                      && validText(request.resource.data.get('desc', ''), 2000)
                      && validImageList();
      allow update: if isAdmin() || isAuthorContentUpdate(resource.data.authorId)
                      || isSafeCounterUpdate()
                      || isSafeVoteUpdate()
                      || isSafeMultiVoteUpdate();
      allow delete: if isAdmin() || isAuthor(resource.data.authorId);

      match /comments/{commentId} {
        allow read:   if true;
        allow create: if signedIn()
                        && request.resource.data.authorId == request.auth.uid
                        && validText(request.resource.data.text, 500);
        allow update: if isAdmin() || isAuthorContentUpdate(resource.data.authorId);
        allow delete: if isAdmin() || isAuthor(resource.data.authorId);
        match /replies/{replyId} {
          allow read: if true;
          allow create: if false;
          allow update: if false;
          allow delete: if isAdmin() || isAuthor(resource.data.authorId);
        }
      }

      match /secret/{docId} {
        allow read:   if isAdmin();
        allow create: if isAdmin() ||
          (signedIn() && get(/databases/$(database)/documents/feeds/$(postId)).data.authorId == request.auth.uid);
        allow update: if isAdmin();
        allow delete: if isAdmin();
      }

      match /acrostics/{acrosticId} {
        allow read:   if true;
        allow create: if false;
        allow update: if isAdmin();
        allow delete: if isAdmin() || isAuthor(resource.data.authorId);
        match /replies/{replyId} {
          allow read: if true;
          allow create: if false;
          allow update: if false;
          allow delete: if isAdmin() || isAuthor(resource.data.authorId);
        }
      }

      match /multi_naming/{itemId} {
        allow read: if true; allow create: if false; allow update: if isAdmin(); allow delete: if isAdmin() || isAuthor(resource.data.authorId);
        match /replies/{replyId} { allow read: if true; allow create: if false; allow update: if false; allow delete: if isAdmin() || isAuthor(resource.data.authorId); }
      }
      match /multi_drip/{itemId} {
        allow read: if true; allow create: if false; allow update: if isAdmin(); allow delete: if isAdmin() || isAuthor(resource.data.authorId);
        match /replies/{replyId} { allow read: if true; allow create: if false; allow update: if false; allow delete: if isAdmin() || isAuthor(resource.data.authorId); }
      }
      match /multi_fill/{itemId} {
        allow read: if true; allow create: if false; allow update: if isAdmin(); allow delete: if isAdmin() || isAuthor(resource.data.authorId);
        match /replies/{replyId} { allow read: if true; allow create: if false; allow update: if false; allow delete: if isAdmin() || isAuthor(resource.data.authorId); }
      }

      match /debate_votes/{voteId} {
        allow read:   if signedIn() && request.auth.uid == voteId;
        allow create, update, delete: if false;
      }
      match /view_events/{eventId} { allow read, write: if false; }
      match /viewers/{viewerId} { allow read, write: if false; }
    }

    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if signedIn()
        && request.resource.data.reporterId == request.auth.uid
        && validText(request.resource.data.reason, 500);
      allow update, delete: if isAdmin();
    }

    match /notifications/{noticeId} {
      allow read: if signedIn() && resource.data.uid == request.auth.uid;
      allow update: if validNotificationReadUpdate();
      allow create, delete: if false;
    }
    match /notifications/{uid}/items/{noticeId} { allow read: if isAuthor(uid); allow write: if false; }

    match /follows/{followId} {
      allow read: if signedIn()
        && (resource.data.followerId == request.auth.uid || resource.data.followedId == request.auth.uid || isAdmin());
      allow create: if signedIn()
        && request.resource.data.followerId == request.auth.uid
        && request.resource.data.followedId is string
        && request.resource.data.followedId != request.auth.uid
        && request.resource.data.keys().hasOnly(['followerId', 'followerName', 'followedId', 'followedName', 'createdAt']);
      allow delete: if signedIn() && (resource.data.followerId == request.auth.uid || isAdmin());
      allow update: if false;
    }

    match /feedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if signedIn()
        && request.resource.data.reporterId == request.auth.uid
        && validText(request.resource.data.message, 1000);
      allow update, delete: if isAdmin();
    }

    match /game_rooms/{roomId} {
      allow read: if true;
      allow create: if signedIn();
      allow update: if isAdmin() || isGameHost(roomId);
      allow delete: if isAdmin();
      match /players/{playerId} {
        allow read: if true;
        allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
        allow update: if signedIn() && (playerId == request.auth.uid || resource.data.uid == request.auth.uid || isGameHost(roomId));
        allow delete: if isAdmin() || isGameHost(roomId) || isAuthor(playerId);
      }
      match /chats/{chatId} {
        allow read: if true;
        allow create: if (isGameRoomPlayer(roomId) || isGameHost(roomId))
          && validText(request.resource.data.get('text', ''), 500)
          && request.resource.data.uid == request.auth.uid;
        allow update: if false;
        allow delete: if isAdmin() || isGameHost(roomId);
      }
    }

    match /config/{docId} { allow read, write: if isAdmin(); }
    match /ai_ladder_bonus/{docId} { allow read: if isAdmin(); allow write: if false; }
    match /missions/{missionId}      { allow read: if true; allow write: if isAdmin(); }
    match /categories/{categoryId}   { allow read: if true; allow write: if isAdmin(); }
    match /topics/{topicId}          { allow read: if true; allow write: if isAdmin(); }
    match /usage_stats/{docId}       { allow read: if isAdmin(); allow write: if false; }
    match /system_jobs/{docId}       { allow read: if isAdmin(); allow write: if false; }
    match /rate_limits/{docId}       { allow read, write: if false; }
    match /upload_usage/{docId}      { allow read, write: if false; }
    match /deleted_posts/{docId}     { allow read, write: if isAdmin(); }
    match /soso_feed_posts/{postId}  { allow read: if true; allow write: if false; }
    match /point_awards/{awardId}    { allow read, write: if false; }
    match /ai_king_usage/{docId}     { allow read: if isAdmin(); allow write: if false; }
    match /ai_reports/{docId}        { allow read: if isAdmin(); allow write: if false; }

    match /hot_potatoes/{potatoId} {
      allow read: if true;
      allow write: if false;
      match /comments/{commentId} { allow read: if true; allow write: if false; }
    }

    match /{document=**} { allow read, write: if false; }
  }
}
