rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isRegisteredUser() {
      return signedIn()
        && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    function isAuthor(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function validText(value, maxLength) {
      return value is string && value.size() <= maxLength;
    }

    function validNickname(value) {
      return value is string
        && value.size() >= 2
        && value.size() <= 12
        && value.matches('^[가-힣a-zA-Z0-9_]+$');
    }

    function validImages(data) {
      return !('images' in data)
        || (data.images is list && data.images.size() <= 20);
    }

    function validTags(data) {
      return !('tags' in data)
        || (data.tags is list && data.tags.size() <= 8);
    }

    function canReadFeed(postId) {
      let feed = get(/databases/$(database)/documents/feeds/$(postId));
      return feed.data.hidden != true
        || isAdmin()
        || isAuthor(feed.data.authorId);
    }

    function validUserSelfUpdate(userId) {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return isAuthor(userId)
        && changed.hasOnly(['photoURL', 'bio', 'updatedAt'])
        && validText(request.resource.data.get('bio', ''), 500);
    }

    function validNotificationReadUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return signedIn()
        && resource.data.uid == request.auth.uid
        && changed.hasOnly(['read', 'readAt'])
        && request.resource.data.read == true;
    }

    match /admins/{uid} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /admin_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /ai_usage/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /users/{userId} {
      allow read: if isAuthor(userId) || isAdmin();
      allow create: if false;
      allow update: if isAdmin() || validUserSelfUpdate(userId);
      allow delete: if false;

      match /point_logs/{logId} {
        allow read: if isAuthor(userId) || isAdmin();
        allow write: if false;
      }

      match /scraps/{scrapId} {
        allow read: if isAuthor(userId) || isAdmin();
        allow create: if isAuthor(userId)
          && request.resource.data.keys().hasOnly(['postId', 'createdAt'])
          && request.resource.data.postId is string;
        allow delete: if isAuthor(userId) || isAdmin();
        allow update: if false;
      }
    }

    match /nicknames/{nickname} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /feeds/{postId} {
      allow read: if resource.data.hidden != true
        || isAdmin()
        || isAuthor(resource.data.authorId);
      allow create: if false;
      allow update, delete: if isAdmin();

      match /comments/{commentId} {
        allow read: if canReadFeed(postId);
        allow create: if signedIn()
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.keys().hasOnly([
            'text', 'authorId', 'authorName', 'authorPhoto', 'isGuest',
            'side', 'reactions', 'reactedWith', 'createdAt'
          ])
          && validText(request.resource.data.text, 500)
          && validText(request.resource.data.get('authorName', ''), 40);
        allow update: if false;
        allow delete: if isAdmin() || isAuthor(resource.data.authorId);

        match /replies/{replyId} {
          allow read: if canReadFeed(postId);
          allow create: if signedIn()
            && request.resource.data.authorId == request.auth.uid
            && request.resource.data.keys().hasOnly([
              'text', 'authorId', 'authorName', 'authorPhoto', 'createdAt'
            ])
            && validText(request.resource.data.text, 500);
          allow update: if false;
          allow delete: if isAdmin() || isAuthor(resource.data.authorId);
        }
      }

      match /multi_drip/{itemId} {
        allow read: if canReadFeed(postId);
        allow write: if false;

        match /replies/{replyId} {
          allow read: if canReadFeed(postId);
          allow write: if false;
        }
      }

      match /viewers/{viewerId} {
        allow read, write: if false;
      }
    }

    match /reports/{reportId} {
      allow read: if isAdmin()
        || (signedIn() && resource.data.reporterId == request.auth.uid);
      allow create: if isRegisteredUser()
        && request.resource.data.reporterId == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'postId', 'postTitle', 'reporterId', 'reporterName',
          'reason', 'resolved', 'createdAt'
        ])
        && validText(request.resource.data.reason, 500)
        && request.resource.data.resolved == false;
      allow update, delete: if isAdmin();
    }

    match /notifications/{noticeId} {
      allow read: if signedIn() && resource.data.uid == request.auth.uid;
      allow update: if validNotificationReadUpdate();
      allow create, delete: if false;
    }

    match /follows/{followId} {
      allow read: if signedIn()
        && (resource.data.followerId == request.auth.uid
          || resource.data.followedId == request.auth.uid
          || isAdmin());
      allow create: if isRegisteredUser()
        && request.resource.data.followerId == request.auth.uid
        && request.resource.data.followedId is string
        && request.resource.data.followedId != request.auth.uid
        && request.resource.data.keys().hasOnly([
          'followerId', 'followerName', 'followedId', 'followedName', 'createdAt'
        ]);
      allow delete: if signedIn()
        && (resource.data.followerId == request.auth.uid || isAdmin());
      allow update: if false;
    }

    match /feedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if isRegisteredUser()
        && request.resource.data.reporterId == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'reporterId', 'reporterName', 'message', 'createdAt'
        ])
        && validText(request.resource.data.message, 1000);
      allow update, delete: if isAdmin();
    }

    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /site_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /topics/{topicId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /usage_stats/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /system_jobs/{docId} {
      allow read, write: if false;
    }

    match /rate_limits/{docId} {
      allow read, write: if false;
    }

    match /upload_usage/{docId} {
      allow read, write: if false;
    }

    match /deleted_posts/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /deleted_users/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /point_awards/{awardId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
