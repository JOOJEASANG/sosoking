rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function verifiedAdminEmail() {
      return signedIn()
        && request.auth.token.email != null
        && request.auth.token.email_verified == true
        ? request.auth.token.email
        : '';
    }

    function isAdmin() {
      return signedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/admins/$(verifiedAdminEmail()))
      );
    }

    function caseDoc(caseId) {
      return get(/databases/$(database)/documents/cases/$(caseId));
    }

    function resultDoc(caseId) {
      return get(/databases/$(database)/documents/results/$(caseId));
    }

    function isCaseOwner(caseId) {
      return signedIn() && caseDoc(caseId).data.userId == request.auth.uid;
    }

    function isCasePublic(caseId) {
      return caseDoc(caseId).data.isPublic == true;
    }

    function isResultPublic(caseId) {
      return resultDoc(caseId).data.isPublic == true;
    }

    function canReadPublicCourt(caseId) {
      return signedIn() && (isCasePublic(caseId) || isResultPublic(caseId) || isCaseOwner(caseId) || isAdmin());
    }

    match /admins/{uidOrEmail} {
      allow read: if signedIn() && (
        request.auth.uid == uidOrEmail ||
        verifiedAdminEmail() == uidOrEmail ||
        isAdmin()
      );
      allow write: if false;
    }

    match /admin_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      // 프로필 생성·수정·삭제는 Callable Function에서만 처리한다.
      allow create, update, delete: if false;
    }

    match /user_names/{key} {
      allow read: if true;
      // 닉네임 예약은 setNickname의 서버 트랜잭션으로만 변경한다.
      allow create, update, delete: if false;
    }

    match /cases/{caseId} {
      allow read: if signedIn() && (
        resource.data.userId == request.auth.uid ||
        isAdmin()
      );
      // 사건 접수는 submitCase Callable Function에서만 처리한다.
      allow create: if false;
      allow update: if isAdmin() || (
        signedIn() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isPublic']) &&
        request.resource.data.isPublic is bool
      );
      // 삭제는 deleteMyCase 또는 deleteCourtPost에서 연관 데이터를 함께 정리한다.
      allow delete: if false;
    }

    match /results/{caseId} {
      allow read: if signedIn() && (
        isCaseOwner(caseId) ||
        resource.data.isPublic == true ||
        isAdmin()
      );
      allow update: if isAdmin() || (
        signedIn() &&
        isCaseOwner(caseId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isPublic']) &&
        request.resource.data.isPublic is bool
      );
      allow create, delete: if false;
    }

    match /result_reactions/{caseId} {
      allow read: if canReadPublicCourt(caseId);
      allow write: if false;
      match /votes/{uid} {
        allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
        allow write: if false;
      }
    }

    match /court_comments/{caseId}/items/{commentId} {
      allow read: if canReadPublicCourt(caseId);
      allow write: if false;
    }

    match /court_comment_stats/{caseId} {
      allow read: if canReadPublicCourt(caseId);
      allow write: if false;
    }

    match /usage_stats/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /rate_limits/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if false;
    }

    match /comment_limits/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if false;
    }

    match /title_suggestion_limits/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if false;
    }

    match /reports/{reportId} {
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly(['caseId', 'reason', 'status', 'createdAt', 'userId'])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.caseId is string
        && request.resource.data.reason is string
        && request.resource.data.reason.size() > 0
        && request.resource.data.reason.size() <= 300
        && request.resource.data.status == 'pending';
      allow read, update, delete: if isAdmin();
    }

    match /absurd_cases/{caseId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /site_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 향후 공개 설정과 운영 전용 설정을 분리할 수 있도록 비공개 저장소를 준비한다.
    match /admin_settings/{docId} {
      allow read, write: if isAdmin();
    }

    match /policy_docs/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
