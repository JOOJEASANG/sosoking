rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isSessionParticipant() {
      return request.auth != null && (
        (resource.data.plaintiff is map && resource.data.plaintiff.userId == request.auth.uid) ||
        (resource.data.defendant is map && resource.data.defendant.userId == request.auth.uid)
      );
    }

    function validNickname(nickname) {
      return nickname is string
        && nickname.size() >= 2
        && nickname.size() <= 12
        && nickname.matches('^[가-힣a-zA-Z0-9_]+$');
    }

    function validUserProfile(userId) {
      return request.auth != null
        && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['nickname', 'nicknameUpdatedAt'])
        && validNickname(request.resource.data.nickname);
    }

    function validNicknameClaim(nickname) {
      return request.auth != null
        && validNickname(nickname)
        && request.resource.data.uid == request.auth.uid;
    }

    function isVoteOnlyUpdate() {
      return request.auth != null &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['votesA', 'votesB']) &&
        (
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['votesA']) &&
            request.resource.data.votesA is int &&
            request.resource.data.votesA == (resource.data.votesA is int ? resource.data.votesA : 0) + 1
          ) ||
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['votesB']) &&
            request.resource.data.votesB is int &&
            request.resource.data.votesB == (resource.data.votesB is int ? resource.data.votesB : 0) + 1
          )
        );
    }

    function validFeedPost() {
      return request.auth != null
        && request.resource.data.title is string
        && request.resource.data.title.size() >= 4
        && request.resource.data.title.size() <= 90
        && request.resource.data.content is string
        && request.resource.data.content.size() >= 5
        && request.resource.data.content.size() <= 1200
        && request.resource.data.question is string
        && request.resource.data.question.size() <= 90
        && request.resource.data.options is list
        && request.resource.data.options.size() >= 2
        && request.resource.data.options.size() <= 4
        && request.resource.data.tags is list
        && request.resource.data.tags.size() <= 6
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.status == 'published'
        && request.resource.data.views == 0
        && request.resource.data.likes == 0
        && request.resource.data.comments == 0
        && request.resource.data.voteTotal == 0;
    }

    function isFeedCounterUpdate() {
      return request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views', 'likes', 'comments', 'topComment', 'votes', 'voteTotal'])
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['views']) || request.resource.data.views == resource.data.views + 1)
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['likes']) || request.resource.data.likes == resource.data.likes + 1)
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['comments']) || request.resource.data.comments == resource.data.comments + 1)
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['voteTotal']) || request.resource.data.voteTotal == resource.data.voteTotal + 1)
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['topComment']) || request.resource.data.topComment is string && request.resource.data.topComment.size() <= 300);
    }

    function validFeedComment() {
      return request.auth != null
        && request.resource.data.text is string
        && request.resource.data.text.size() >= 2
        && request.resource.data.text.size() <= 300
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.likes == 0;
    }

    function validFeedVoter(voterId) {
      return request.auth != null
        && voterId == request.auth.uid
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.option is string
        && request.resource.data.option.size() >= 1
        && request.resource.data.option.size() <= 40;
    }

    match /admins/{uid} { allow read: if request.auth != null && request.auth.uid == uid; allow write: if false; }
    match /categories/{catId} { allow read: if true; allow write: if isAdmin(); }
    match /topics/{topicId} { allow read: if resource.data.status == 'active' || isAdmin(); allow create: if isAdmin(); allow update: if isAdmin() || isVoteOnlyUpdate(); allow delete: if isAdmin(); }
    match /debate_sessions/{sessionId} { allow get: if request.auth != null; allow list: if isSessionParticipant() || isAdmin(); allow create: if false; allow update: if false; allow delete: if isAdmin(); }
    match /random_queue/{topicId} { allow read: if request.auth != null; allow write: if false; }
    match /usage_stats/{docId} { allow read: if isAdmin(); allow write: if false; }
    match /rate_limits/{userId} { allow read, write: if false; }
    match /users/{userId} { allow read: if request.auth != null && request.auth.uid == userId; allow create, update: if validUserProfile(userId); allow delete: if false; }
    match /nicknames/{nickname} { allow read: if request.auth != null; allow create: if validNicknameClaim(nickname) && !exists(/databases/$(database)/documents/nicknames/$(nickname)); allow delete: if request.auth != null && resource.data.uid == request.auth.uid; allow update: if false; }
    match /reports/{reportId} { allow create: if request.auth != null; allow read, update, delete: if isAdmin(); }
    match /site_settings/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /policy_docs/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /feedback/{feedbackId} {
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['category', 'content', 'createdAt'])
        && request.resource.data.content is string
        && request.resource.data.content.size() <= 500;
      allow read, update, delete: if isAdmin();
    }

    match /soso_feed_posts/{postId} {
      allow read: if resource.data.status == 'published' || isAdmin();
      allow create: if validFeedPost();
      allow update: if isAdmin() || isFeedCounterUpdate();
      allow delete: if isAdmin();
      match /comments/{commentId} {
        allow read: if get(/databases/$(database)/documents/soso_feed_posts/$(postId)).data.status == 'published' || isAdmin();
        allow create: if validFeedComment();
        allow update, delete: if isAdmin();
      }
      match /voters/{voterId} {
        allow read: if request.auth != null && voterId == request.auth.uid;
        allow create: if validFeedVoter(voterId) && !exists(/databases/$(database)/documents/soso_feed_posts/$(postId)/voters/$(voterId));
        allow update, delete: if false;
      }
    }
  }
}
