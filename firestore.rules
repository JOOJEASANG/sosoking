rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── 헬퍼 함수 ──────────────────────────────────────────
    function signedIn()  { return request.auth != null; }
    function isAuthor(uid) { return signedIn() && request.auth.uid == uid; }
    function isAdmin()   {
      return signedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function validText(val, maxLen) {
      return val is string && val.size() <= maxLen;
    }
    function validNickname(nick) {
      return nick is string && nick.size() >= 2 && nick.size() <= 12
        && nick.matches('^[가-힣a-zA-Z0-9_]+$');
    }
    function validImageList() {
      return !('images' in request.resource.data)
        || (request.resource.data.images is list
          && request.resource.data.images.size() <= 10);
    }
    function isSafeCounterUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return changed.hasOnly(['commentCount', 'acrosticCount', 'viewCount']);
    }

    function isSafeVoteUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return signedIn()
        && changed.hasOnly(['options', 'votedBy'])
        && request.resource.data.votedBy is list
        && request.resource.data.votedBy.hasAll(resource.data.get('votedBy', []))
        && request.resource.data.votedBy.size() == resource.data.get('votedBy', []).size() + 1
        && request.resource.data.votedBy.hasOnly(resource.data.get('votedBy', []).concat([request.auth.uid]));
    }
    function isCommentReactionUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return changed.hasOnly(['likes', 'likedBy', 'reactions', 'reactedWith']);
    }

    // ── 관리자 ─────────────────────────────────────────────
    match /admins/{uid} {
      allow read:  if signedIn() && request.auth.uid == uid;
      allow write: if false;
    }

    // ── 사이트 설정 / 운영 데이터 ───────────────────────────
    match /site_settings/{docId}  { allow read: if true; allow write: if isAdmin(); }
    match /policy_docs/{docId}    { allow read: if true; allow write: if isAdmin(); }
    match /admin_summaries/{docId} { allow read: if isAdmin(); allow write: if false; }
    match /ai_usage/{docId}        { allow read: if isAdmin(); allow write: if false; }

    // ── 사용자 프로필 ──────────────────────────────────────
    match /users/{userId} {
      allow read:   if isAuthor(userId) || isAdmin();
      allow create: if isAuthor(userId)
                      && validNickname(request.resource.data.get('nickname', ''));
      allow update: if isAuthor(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /nicknames/{nickname} {
      allow read:   if signedIn();
      allow create: if signedIn()
                      && validNickname(nickname)
                      && request.resource.data.uid == request.auth.uid
                      && !exists(/databases/$(database)/documents/nicknames/$(nickname));
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    // ── 피드 (feeds) ───────────────────────────────────────
    match /feeds/{postId} {
      allow read:   if true;
      allow create: if signedIn()
                      && request.resource.data.authorId == request.auth.uid
                      && validText(request.resource.data.title, 100)
                      && validText(request.resource.data.get('desc', ''), 2000)
                      && validImageList();
      allow update: if isAdmin() || isAuthor(resource.data.authorId)
                      || (signedIn() && isSafeCounterUpdate())
                      || isSafeVoteUpdate();
      allow delete: if isAdmin() || isAuthor(resource.data.authorId);

      match /quiz_attempts/{userId} {
        allow read: if true;
        allow create, update, delete: if false;
      }

      match /comments/{commentId} {
        allow read:   if true;
        allow create: if signedIn()
                        && request.resource.data.authorId == request.auth.uid
                        && validText(request.resource.data.text, 500);
        allow update: if isAdmin() || isAuthor(resource.data.authorId)
                        || (signedIn() && isCommentReactionUpdate());
        allow delete: if isAdmin() || isAuthor(resource.data.authorId);
      }

      match /secret/{docId} {
        allow read:   if isAdmin();
        allow create: if isAdmin() ||
          (signedIn() &&
            get(/databases/$(database)/documents/feeds/$(postId)).data.authorId == request.auth.uid);
        allow update: if isAdmin();
        allow delete: if isAdmin();
      }

      match /acrostics/{acrosticId} {
        allow read:   if true;
        allow create: if signedIn()
                        && request.resource.data.authorId == request.auth.uid
                        && validText(request.resource.data.get('text', ''), 500);
        allow update: if isAdmin() || isAuthor(resource.data.authorId)
                        || (signedIn() && isCommentReactionUpdate());
        allow delete: if isAdmin() || isAuthor(resource.data.authorId);
      }

      match /viewers/{userId} {
        allow read, write: if false;
      }
    }

    // ── 미션 ───────────────────────────────────────────────
    match /missions/{missionId} {
      allow read:   if true;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── 신고 ───────────────────────────────────────────────
    match /reports/{reportId} {
      allow create: if signedIn()
                      && request.resource.data.reporterId == request.auth.uid
                      && validText(request.resource.data.get('reason', ''), 300);
      allow read, update, delete: if isAdmin();
    }

    match /users/{userId}/scraps/{scrapId} {
      allow read, write: if isAuthor(userId);
    }

    match /notifications/{notifId} {
      allow read:   if (signedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if (signedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow delete: if (signedIn() && resource.data.userId == request.auth.uid) || isAdmin();
    }

    match /soso_feed_posts/{postId} {
      allow read:  if true;
      allow write: if isAdmin();
      match /comments/{commentId} { allow read: if true; allow write: if isAdmin(); }
    }

    match /categories/{id}     { allow read, write: if isAdmin(); }
    match /system_jobs/{id}    { allow read, write: if isAdmin(); }
    match /usage_stats/{id}    { allow read: if isAdmin(); allow write: if false; }
    match /rate_limits/{id}    { allow read, write: if false; }
    match /feedback/{id}       { allow create: if signedIn(); allow read, update, delete: if isAdmin(); }

    // ── AI 운영 설정 ────────────────────────────────────────
    match /config/{docId} {
      allow read:  if isAdmin();
      allow write: if false;
    }
    match /ai_reports/{docId} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // ── 팔로우 시스템 ──────────────────────────────────────
    match /follows/{followId} {
      allow read:   if signedIn();
      allow create: if signedIn()
                      && request.resource.data.followerId == request.auth.uid
                      && request.resource.data.followedId is string
                      && request.resource.data.followedId != request.auth.uid;
      allow delete: if signedIn() && resource.data.followerId == request.auth.uid;
      allow update: if false;
    }
  }
}