rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isAuthor(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function validText(value, maximum) {
      return value is string && value.size() <= maximum;
    }

    function validOptionalText(field, maximum) {
      return !(field in request.resource.data)
        || request.resource.data[field] == null
        || validText(request.resource.data[field], maximum);
    }

    function validNickname(nickname) {
      return nickname is string
        && nickname.size() >= 2
        && nickname.size() <= 12
        && nickname.matches('^[가-힣a-zA-Z0-9_]+$');
    }

    function validImageList() {
      return !('images' in request.resource.data)
        || (request.resource.data.images is list && request.resource.data.images.size() <= 20);
    }

    function validInitialCounter(field) {
      return !(field in request.resource.data) || request.resource.data[field] == 0;
    }

    function validInitialReactions() {
      return !('reactions' in request.resource.data)
        || (request.resource.data.reactions is map
          && request.resource.data.reactions.get('total', 0) == 0);
    }

    function validFeedCreateShape() {
      return request.resource.data.keys().hasOnly([
          'type', 'cat', 'subtype', 'feedType', 'typeLabel',
          'title', 'desc', 'body', 'subtitle', 'tags', 'images', 'modules',
          'anonymous', 'anonymousMode', 'authorId', 'authorName', 'authorPhoto', 'authorEmail',
          'reactions', 'commentCount', 'acrosticCount', 'viewCount', 'pointsScore',
          'options', 'initials', 'hint', 'keyword', 'evidence',
          'startSentence', 'characters', 'charCount', 'deadline', 'deadlineAt',
          'createdAt', 'updatedAt', 'partyId', 'rankEmoji'
        ])
        && !request.resource.data.keys().hasAny(['hidden', 'hideReason', 'votedBy', 'reactedWith'])
        && validInitialCounter('commentCount')
        && validInitialCounter('acrosticCount')
        && validInitialCounter('viewCount')
        && validInitialCounter('pointsScore')
        && validInitialReactions();
    }

    function isSafeCounterUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return signedIn()
        && changed.hasOnly(['commentCount'])
        && (
          request.resource.data.commentCount == resource.data.get('commentCount', 0) + 1 ||
          request.resource.data.commentCount == resource.data.get('commentCount', 0) - 1
        );
    }

    function isAuthorContentUpdate(authorId) {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return isAuthor(authorId)
        && request.resource.data.authorId == resource.data.authorId
        && !changed.hasAny([
          'authorId', 'authorName', 'authorPhoto', 'authorEmail',
          'reactions', 'reactedWith', 'commentCount', 'acrosticCount',
          'viewCount', 'votedBy', 'pointsScore', 'options', 'modules',
          'hidden', 'hideReason', 'partyId', 'rankEmoji'
        ]);
    }

    function validUserCreate(userId) {
      return isAuthor(userId)
        && request.resource.data.keys().hasOnly([
          'nickname', 'displayName', 'email', 'photoURL', 'provider', 'createdAt', 'updatedAt'
        ])
        && validNickname(request.resource.data.get('nickname', ''))
        && validText(request.resource.data.get('displayName', ''), 50)
        && validText(request.resource.data.get('email', ''), 200)
        && validText(request.resource.data.get('provider', ''), 40)
        && validOptionalText('photoURL', 500);
    }

    function validReservedNickname(userId) {
      return !('nickname' in request.resource.data)
        || request.resource.data.nickname == resource.data.get('nickname', '')
        || (validNickname(request.resource.data.nickname)
          && exists(/databases/$(database)/documents/nicknames/$(request.resource.data.nickname))
          && get(/databases/$(database)/documents/nicknames/$(request.resource.data.nickname)).data.uid == userId);
    }

    function validUserSelfUpdate(userId) {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return isAuthor(userId)
        && changed.hasOnly(['nickname', 'nicknameIcon', 'updatedAt'])
        && validReservedNickname(userId)
        && (!('nicknameIcon' in request.resource.data)
          || request.resource.data.nicknameIcon == null
          || request.resource.data.nicknameIcon is map);
    }

    function validNotificationReadUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return signedIn()
        && (resource.data.uid == request.auth.uid || resource.data.userId == request.auth.uid)
        && changed.hasOnly(['read', 'readAt', 'readAtMs'])
        && request.resource.data.read == true
        && (!('readAtMs' in request.resource.data) || request.resource.data.readAtMs is number)
        && (!('readAt' in request.resource.data) || request.resource.data.readAt is timestamp);
    }

    match /admins/{uid} {
      allow read: if isAuthor(uid);
      allow write: if false;
    }

    match /site_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /policy_docs/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthor(userId) || isAdmin();
      allow create: if validUserCreate(userId);
      allow update: if isAdmin() || validUserSelfUpdate(userId);
      allow delete: if false;

      match /point_logs/{logId} {
        allow read: if isAuthor(userId) || isAdmin();
        allow write: if false;
      }

      match /scraps/{scrapId} {
        allow read: if isAuthor(userId) || isAdmin();
        allow create: if isAuthor(userId) && request.resource.data.postId is string;
        allow delete: if isAuthor(userId) || isAdmin();
        allow update: if false;
      }

      match /ai_results/{resultId} {
        allow read, write: if false;
      }
    }

    match /nicknames/{nickname} {
      allow read: if signedIn();
      allow create: if signedIn()
        && validNickname(nickname)
        && request.resource.data.uid == request.auth.uid
        && !exists(/databases/$(database)/documents/nicknames/$(nickname));
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    match /feeds/{postId} {
      allow read: if true;
      allow create: if signedIn()
        && validFeedCreateShape()
        && request.resource.data.authorId == request.auth.uid
        && validText(request.resource.data.title, 100)
        && validText(request.resource.data.get('desc', ''), 2000)
        && validImageList();
      allow update: if isAdmin()
        || isAuthorContentUpdate(resource.data.authorId)
        || isSafeCounterUpdate();
      allow delete: if isAdmin() || isAuthor(resource.data.authorId);

      match /comments/{commentId} {
        allow read: if true;
        allow create: if signedIn()
          && request.resource.data.authorId == request.auth.uid
          && validText(request.resource.data.text, 500);
        allow update: if isAdmin() || isAuthorContentUpdate(resource.data.authorId);
        allow delete: if isAdmin() || isAuthor(resource.data.authorId);

        match /replies/{replyId} {
          allow read: if true;
          allow create, update: if false;
          allow delete: if isAdmin() || isAuthor(resource.data.authorId);
        }
      }

      match /secret/{docId} {
        allow read: if isAdmin();
        allow create: if isAdmin()
          || (signedIn() && get(/databases/$(database)/documents/feeds/$(postId)).data.authorId == request.auth.uid);
        allow update, delete: if isAdmin();
      }

      match /acrostics/{itemId} {
        allow read: if true;
        allow create: if false;
        allow update: if isAdmin();
        allow delete: if isAdmin() || isAuthor(resource.data.authorId);
        match /replies/{replyId} {
          allow read: if true;
          allow create, update: if false;
          allow delete: if isAdmin() || isAuthor(resource.data.authorId);
        }
      }

      match /multi_naming/{itemId} {
        allow read: if true;
        allow create: if false;
        allow update: if isAdmin();
        allow delete: if isAdmin() || isAuthor(resource.data.authorId);
        match /replies/{replyId} {
          allow read: if true;
          allow create, update: if false;
          allow delete: if isAdmin() || isAuthor(resource.data.authorId);
        }
      }

      match /multi_drip/{itemId} {
        allow read: if true;
        allow create: if false;
        allow update: if isAdmin();
        allow delete: if isAdmin() || isAuthor(resource.data.authorId);
        match /replies/{replyId} {
          allow read: if true;
          allow create, update: if false;
          allow delete: if isAdmin() || isAuthor(resource.data.authorId);
        }
      }

      match /multi_fill/{itemId} {
        allow read: if true;
        allow create: if false;
        allow update: if isAdmin();
        allow delete: if isAdmin() || isAuthor(resource.data.authorId);
        match /replies/{replyId} {
          allow read: if true;
          allow create, update: if false;
          allow delete: if isAdmin() || isAuthor(resource.data.authorId);
        }
      }

      match /{serverOnly=**} {
        allow read, write: if false;
      }
    }

    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if signedIn()
        && request.resource.data.reporterId == request.auth.uid
        && validText(request.resource.data.reason, 500);
      allow update, delete: if isAdmin();
    }

    match /feedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if signedIn()
        && request.resource.data.reporterId == request.auth.uid
        && validText(request.resource.data.message, 1000);
      allow update, delete: if isAdmin();
    }

    match /notifications/{noticeId} {
      allow read: if signedIn()
        && (resource.data.uid == request.auth.uid || resource.data.userId == request.auth.uid);
      allow update: if validNotificationReadUpdate();
      allow create, delete: if false;
    }

    match /notifications/{uid}/items/{noticeId} {
      allow read: if isAuthor(uid);
      allow write: if false;
    }

    match /follows/{followId} {
      allow read: if signedIn()
        && (resource.data.followerId == request.auth.uid
          || resource.data.followedId == request.auth.uid
          || isAdmin());
      allow create: if signedIn()
        && request.resource.data.followerId == request.auth.uid
        && request.resource.data.followedId is string
        && request.resource.data.followedId != request.auth.uid
        && request.resource.data.keys().hasOnly([
          'followerId', 'followerName', 'followedId', 'followedName', 'createdAt'
        ]);
      allow delete: if signedIn()
        && (resource.data.followerId == request.auth.uid || isAdmin());
      allow update: if false;
    }

    match /config/site_features {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /config/{docId} {
      allow read, write: if isAdmin();
    }

    match /missions/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /topics/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /admin_summaries/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /ai_usage/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /usage_stats/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /system_jobs/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /deleted_posts/{docId} {
      allow read, write: if isAdmin();
    }

    // 현재 자료·토론·사용량 데이터는 Cloud Functions에서만 읽고 씁니다.
    match /materials/{document=**} { allow read, write: if false; }
    match /debates/{document=**} { allow read, write: if false; }
    match /generation_runs/{document=**} { allow read, write: if false; }
    match /rate_limits/{document=**} { allow read, write: if false; }
    match /upload_usage/{document=**} { allow read, write: if false; }
    match /point_awards/{document=**} { allow read, write: if false; }
    match /ai_king_usage/{document=**} { allow read, write: if false; }
    match /ai_reports/{document=**} { allow read, write: if false; }

    // 서비스에서 제거된 게임·정치·구형 콘텐츠는 과거 데이터까지 공개하지 않습니다.
    match /game_rooms/{document=**} { allow read, write: if false; }
    match /hot_potatoes/{document=**} { allow read, write: if false; }
    match /jabdam_posts/{document=**} { allow read, write: if false; }
    match /wordchain_entries/{document=**} { allow read, write: if false; }
    match /chosung_puzzles/{document=**} { allow read, write: if false; }
    match /soso_feed_posts/{document=**} { allow read, write: if false; }
    match /ai_ladder_bonus/{document=**} { allow read, write: if false; }
    match /party_manifestos/{document=**} { allow read, write: if false; }
    match /parties/{document=**} { allow read, write: if false; }
    match /elections/{document=**} { allow read, write: if false; }
    match /party_activities/{document=**} { allow read, write: if false; }
    match /daily_news/{document=**} { allow read, write: if false; }
    match /political_crises/{document=**} { allow read, write: if false; }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
