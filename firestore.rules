rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn()  { return request.auth != null; }
    function isAuthor(uid) { return signedIn() && request.auth.uid == uid; }
    function isAdmin()   {
      return signedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function validText(val, maxLen) {
      return val is string && val.size() <= maxLen;
    }
    function validNickname(nick) {
      return nick is string && nick.size() >= 2 && nick.size() <= 12
        && nick.matches('^[가-힣a-zA-Z0-9_]+$');
    }
    function validImageList() {
      return !('images' in request.resource.data)
        || (request.resource.data.images is list && request.resource.data.images.size() <= 20);
    }
    function validInitialCounter(field) {
      return !(field in request.resource.data) || request.resource.data[field] == 0;
    }
    function validInitialReactions() {
      return !('reactions' in request.resource.data)
        || (request.resource.data.reactions is map
          && request.resource.data.reactions.get('total', 0) == 0);
    }
    function validFeedCreateShape() {
      return request.resource.data.keys().hasOnly([
          'type', 'cat', 'subtype', 'typeLabel',
          'title', 'desc', 'body', 'subtitle', 'tags', 'images', 'modules',
          'anonymous', 'anonymousMode', 'authorId', 'authorName', 'authorPhoto', 'authorEmail',
          'reactions', 'commentCount', 'acrosticCount', 'viewCount', 'pointsScore',
          'options', 'quizMode', 'initials', 'hint', 'keyword', 'evidence',
          'startSentence', 'characters', 'charCount', 'deadline', 'deadlineAt', 'createdAt', 'updatedAt'
        ])
        && !request.resource.data.keys().hasAny(['hidden', 'hideReason', 'votedBy', 'reactedWith'])
        && validInitialCounter('commentCount')
        && validInitialCounter('acrosticCount')
        && validInitialCounter('viewCount')
        && validInitialCounter('pointsScore')
        && validInitialReactions();
    }
    function isSafeCounterUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return signedIn()
        && (
          (changed.hasOnly(['commentCount'])
            && (
              request.resource.data.commentCount == resource.data.get('commentCount', 0) + 1 ||
              request.resource.data.commentCount == resource.data.get('commentCount', 0) - 1
            ))
          ||
          (changed.hasOnly(['acrosticCount'])
            && (
              request.resource.data.acrosticCount == resource.data.get('acrosticCount', 0) + 1 ||
              request.resource.data.acrosticCount == resource.data.get('acrosticCount', 0) - 1
            ))
        );
    }

    function isSafeVoteUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return signedIn()
        && changed.hasOnly(['options', 'votedBy'])
        && request.resource.data.votedBy is list
        && request.resource.data.votedBy.hasAll(resource.data.get('votedBy', []))
        && !(request.auth.uid in resource.data.get('votedBy', []))
        && request.resource.data.votedBy.hasAny([request.auth.uid])
        && request.resource.data.votedBy.size() == resource.data.get('votedBy', []).size() + 1;
    }
    function isSafeMultiVoteUpdate() {
      return false;
    }
    function isAuthorContentUpdate(authorId) {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return isAuthor(authorId)
        && request.resource.data.authorId == resource.data.authorId
        && !changed.hasAny(['authorId', 'authorName', 'authorPhoto', 'authorEmail', 'reactions', 'reactedWith', 'commentCount', 'acrosticCount', 'viewCount', 'votedBy', 'pointsScore']);
    }

    function isMultiItemReactionOrReplyCountUpdate() {
      return false;
    }

    function validReplyCreate() {
      return false;
    }
    function validMultiParticipationCreate() {
      return false;
    }
    function validUserSelfUpdate(userId) {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return isAuthor(userId)
        && changed.hasOnly(['nicknameIcon', 'updatedAt'])
        && (!('nicknameIcon' in request.resource.data)
          || request.resource.data.nicknameIcon == null
          || request.resource.data.nicknameIcon is map);
    }
    function validNotificationReadUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return signedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == resource.data.uid
        && changed.hasOnly(['read', 'readAt', 'readAtMs'])
        && request.resource.data.read is bool
        && (!('readAtMs' in request.resource.data) || request.resource.data.readAtMs is number)
        && (!('readAt' in request.resource.data) || request.resource.data.readAt is timestamp);
    }

    match /admins/{uid} {
      allow read:  if signedIn() && request.auth.uid == uid;
      allow write: if false;
    }

    match /site_settings/{docId}  { allow read: if true; allow write: if isAdmin(); }
    match /policy_docs/{docId}    { allow read: if true; allow write: if isAdmin(); }
    match /admin_summaries/{docId} { allow read: if isAdmin(); allow write: if false; }
    match /ai_usage/{docId}        { allow read: if isAdmin(); allow write: if false; }

    match /users/{userId} {
      allow read:   if isAuthor(userId) || isAdmin();
      allow create: if isAuthor(userId)
                      && validNickname(request.resource.data.get('nickname', ''));
      allow update: if isAdmin() || validUserSelfUpdate(userId);
      allow delete: if isAdmin();

      match /point_logs/{logId} {
        allow read: if isAuthor(userId) || isAdmin();
        allow create, update, delete: if false;
      }
    }

    match /nicknames/{nickname} {
      allow read:   if signedIn();
      allow create: if signedIn()
                      && validNickname(nickname)
                      && request.resource.data.uid == request.auth.uid
                      && !exists(/databases/$(database)/documents/nicknames/$(nickname));
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    match /feeds/{postId} {
      allow read:   if true;
      allow create: if signedIn()
                      && validFeedCreateShape()
                      && request.resource.data.authorId == request.auth.uid
                      && validText(request.resource.data.title, 100)
                      && validText(request.resource.data.get('desc', ''), 2000)
                      && validImageList();
      allow update: if isAdmin() || isAuthorContentUpdate(resource.data.authorId)
                      || isSafeCounterUpdate()
                      || isSafeVoteUpdate()
                      || isSafeMultiVoteUpdate();
      allow delete: if isAdmin() || isAuthor(resource.data.authorId);

      match /quiz_attempts/{userId} {
        allow read: if true;
        allow create, update, delete: if false;
      }

      match /comments/{commentId} {
        allow read:   if true;
        allow create: if signedIn()
                        && request.resource.data.authorId == request.auth.uid
                        && validText(request.resource.data.text, 500);
        allow update: if isAdmin() || isAuthorContentUpdate(resource.data.authorId);
        allow delete: if isAdmin() || isAuthor(resource.data.authorId);

        match /replies/{replyId} {
          allow read: if true;
          allow create: if false;
          allow update: if false;
          allow delete: if isAdmin() || isAuthor(resource.data.authorId);
        }
      }

      match /secret/{docId} {
        allow read:   if isAdmin();
        allow create: if isAdmin() ||
          (signedIn() &&
            get(/databases/$(database)/documents/feeds/$(postId)).data.authorId == request.auth.uid);
        allow update: if isAdmin();
        allow delete: if isAdmin();
      }

      match /acrostics/{acrosticId} {
        allow read:   if true;
        allow create: if signedIn()
                        && request.resource.data.authorId == request.auth.uid
                        && validText(request.resource.data.get('text', ''), 500);
        allow update: if isAdmin() || isAuthorContentUpdate(resource.data.authorId);
        allow delete: if isAdmin() || isAuthor(resource.data.authorId);

        match /replies/{replyId} {
          allow read: if true;
          allow create: if false;
          allow update: if false;
          allow delete: if isAdmin() || isAuthor(resource.data.authorId);
        }
      }

      match /multi_naming/{itemId} {
        allow read: if true;
        allow create: if false;
        allow update: if isAdmin();
        allow delete: if isAdmin() || isAuthor(resource.data.authorId);
        match /replies/{replyId} {
          allow read: if true;
          allow create: if false;
          allow update: if false;
          allow delete: if isAdmin() || isAuthor(resource.data.authorId);
        }
      }
      match /multi_acrostic/{itemId} {
        allow read: if true;
        allow create: if false;
        allow update: if isAdmin();
        allow delete: if isAdmin() || isAuthor(resource.data.authorId);
        match /replies/{replyId} {
          allow read: if true;
          allow create: if false;
          allow update: if false;
          allow delete: if isAdmin() || isAuthor(resource.data.authorId);
        }
      }
      match /multi_relay/{itemId} {
        allow read: if true;
        allow create: if false;
        allow update: if isAdmin();
        allow delete: if isAdmin() || isAuthor(resource.data.authorId);
        match /replies/{replyId} {
          allow read: if true;
          allow create: if false;
          allow update: if false;
          allow delete: if isAdmin() || isAuthor(resource.data.authorId);
        }
      }
      match /multi_fill/{itemId} {
        allow read: if true;
        allow create: if false;
        allow update: if isAdmin();
        allow delete: if isAdmin() || isAuthor(resource.data.authorId);
        match /replies/{replyId} {
          allow read: if true;
          allow create: if false;
          allow update: if false;
          allow delete: if isAdmin() || isAuthor(resource.data.authorId);
        }
      }

      match /view_events/{eventId} { allow read, write: if false; }
      match /viewers/{viewerId} { allow read, write: if false; }
    }

    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if signedIn()
        && request.resource.data.reporterId == request.auth.uid
        && validText(request.resource.data.reason, 500);
      allow update, delete: if isAdmin();
    }

    match /notifications/{noticeId} {
      allow read: if signedIn() && resource.data.uid == request.auth.uid;
      allow update: if validNotificationReadUpdate();
      allow create, delete: if false;
    }

    match /notifications/{uid}/items/{noticeId} {
      allow read: if isAuthor(uid);
      allow write: if false;
    }

    match /feedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if signedIn()
        && request.resource.data.authorId == request.auth.uid
        && validText(request.resource.data.message, 1000);
      allow update, delete: if isAdmin();
    }

    match /game_rooms/{roomId} {
      allow read: if true;
      allow create: if signedIn();
      allow update: if signedIn();
      allow delete: if isAdmin();
    }

    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /missions/{missionId}      { allow read: if true; allow write: if isAdmin(); }
    match /categories/{categoryId}   { allow read: if true; allow write: if isAdmin(); }
    match /topics/{topicId}          { allow read: if true; allow write: if isAdmin(); }
    match /usage_stats/{docId}       { allow read: if isAdmin(); allow write: if false; }
    match /system_jobs/{docId}       { allow read: if isAdmin(); allow write: if false; }
    match /rate_limits/{docId}       { allow read, write: if false; }
    match /upload_usage/{docId}      { allow read, write: if false; }
    match /deleted_posts/{docId}     { allow read, write: if isAdmin(); }
    match /soso_feed_posts/{postId}  { allow read: if true; allow write: if false; }
    match /point_awards/{awardId}    { allow read, write: if false; }

    match /weekly_fill/{weekKey} {
      allow read: if true;
      allow write: if false;

      match /answers/{userId} {
        allow read: if true;
        allow create: if isAuthor(userId)
                        && request.resource.data.authorId == request.auth.uid
                        && validText(request.resource.data.get('filled', ''), 300)
                        && request.resource.data.blanks is list
                        && request.resource.data.blanks.size() <= 5;
        allow update: if false;
        allow delete: if isAdmin();
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}