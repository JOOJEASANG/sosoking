rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function caseDoc(caseId) {
      return get(/databases/$(database)/documents/cases/$(caseId));
    }

    function isCaseOwner(caseId) {
      return signedIn() && caseDoc(caseId).data.userId == request.auth.uid;
    }

    function isCasePublic(caseId) {
      return caseDoc(caseId).data.isPublic == true;
    }

    function validUserProfile(uid) {
      return request.resource.data.keys().hasOnly([
          'uid', 'email', 'nickname', 'provider', 'isAnonymous', 'createdAt', 'updatedAt'
        ])
        && request.resource.data.uid == uid
        && request.resource.data.nickname is string
        && request.resource.data.nickname.size() >= 2
        && request.resource.data.nickname.size() <= 20
        && request.resource.data.email is string
        && request.resource.data.email.size() <= 120
        && request.resource.data.provider is string
        && request.resource.data.provider.size() <= 60;
    }

    function validUserName(key) {
      return request.resource.data.keys().hasOnly(['uid', 'nickname', 'key', 'createdAt', 'updatedAt'])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.key == key
        && request.resource.data.nickname is string
        && request.resource.data.nickname.size() >= 2
        && request.resource.data.nickname.size() <= 20;
    }

    function validCaseCreate() {
      return request.resource.data.keys().hasOnly([
          'userId', 'caseTitle', 'caseDescription', 'grievanceIndex', 'nickname',
          'desiredVerdict', 'selectedJudge', 'status', 'isPublic', 'reportCount', 'createdAt'
        ])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.caseTitle is string
        && request.resource.data.caseTitle.size() > 0
        && request.resource.data.caseTitle.size() <= 30
        && request.resource.data.caseDescription is string
        && request.resource.data.caseDescription.size() > 0
        && request.resource.data.caseDescription.size() <= 200
        && request.resource.data.grievanceIndex is int
        && request.resource.data.grievanceIndex >= 1
        && request.resource.data.grievanceIndex <= 10
        && request.resource.data.nickname is string
        && request.resource.data.nickname.size() <= 30
        && request.resource.data.desiredVerdict is string
        && request.resource.data.desiredVerdict.size() <= 100
        && request.resource.data.selectedJudge is string
        && request.resource.data.status == 'pending'
        && request.resource.data.isPublic == false
        && request.resource.data.reportCount == 0;
    }

    match /admins/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if false;
    }

    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if signedIn() && request.auth.uid == uid && validUserProfile(uid);
      allow update: if signedIn() && request.auth.uid == uid && validUserProfile(uid);
      allow delete: if isAdmin();
    }

    match /user_names/{key} {
      allow read: if true;
      allow create: if signedIn()
        && !exists(/databases/$(database)/documents/user_names/$(key))
        && validUserName(key);
      allow update: if signedIn()
        && resource.data.uid == request.auth.uid
        && validUserName(key);
      allow delete: if signedIn() && (resource.data.uid == request.auth.uid || isAdmin());
    }

    match /cases/{caseId} {
      allow read: if signedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.isPublic == true ||
        isAdmin()
      );
      allow create: if signedIn() && validCaseCreate();
      allow update: if isAdmin() || (
        signedIn() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isPublic']) &&
        request.resource.data.isPublic is bool
      );
      allow delete: if isAdmin();
    }

    match /results/{caseId} {
      allow read: if signedIn() && (
        isCaseOwner(caseId) ||
        resource.data.isPublic == true ||
        isAdmin()
      );
      allow update: if isAdmin() || (
        signedIn() &&
        isCaseOwner(caseId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'isPublic', 'caseTitle', 'grievanceIndex', 'judgeType', 'sentence', 'createdAt'
        ]) &&
        request.resource.data.isPublic is bool
      );
      allow create: if false;
      allow delete: if isAdmin();
    }

    match /usage_stats/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /rate_limits/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if false;
    }

    match /reports/{reportId} {
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly(['caseId', 'reason', 'status', 'createdAt', 'userId'])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.caseId is string
        && request.resource.data.reason is string
        && request.resource.data.reason.size() > 0
        && request.resource.data.reason.size() <= 300
        && request.resource.data.status == 'pending';
      allow read, update, delete: if isAdmin();
    }

    match /site_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /policy_docs/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
