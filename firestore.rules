rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isAdmin() { return signedIn() && request.auth.token.admin == true; }

    match /programs/{programId} {
      allow read: if resource.data.status == 'published' || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /memories/{memoryId} {
      allow read: if resource.data.status == 'approved' || isAdmin();
      allow create: if request.resource.data.keys().hasOnly([
        'nickname','programTitle','content','status','createdAt'
      ])
      && request.resource.data.nickname is string
      && request.resource.data.nickname.size() >= 1
      && request.resource.data.nickname.size() <= 20
      && request.resource.data.programTitle is string
      && request.resource.data.programTitle.size() >= 1
      && request.resource.data.programTitle.size() <= 60
      && request.resource.data.content is string
      && request.resource.data.content.size() >= 2
      && request.resource.data.content.size() <= 300
      && request.resource.data.status == 'pending';
      allow update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
