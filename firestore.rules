rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn()  { return request.auth != null; }
    function isAuthor(uid) { return signedIn() && request.auth.uid == uid; }
    function isAdmin()   {
      return signedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function validText(val, maxLen) {
      return val is string && val.size() <= maxLen;
    }
    function validNickname(nick) {
      return nick is string && nick.size() >= 2 && nick.size() <= 12
        && nick.matches('^[가-힣a-zA-Z0-9_]+$');
    }
    function validImageList() {
      return !('images' in request.resource.data)
        || (request.resource.data.images is list);
    }
    function isSafeCounterUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return signedIn()
        && (
          (changed.hasOnly(['commentCount'])
            && (
              request.resource.data.commentCount == resource.data.get('commentCount', 0) + 1 ||
              request.resource.data.commentCount == resource.data.get('commentCount', 0) - 1
            ))
          ||
          (changed.hasOnly(['acrosticCount'])
            && (
              request.resource.data.acrosticCount == resource.data.get('acrosticCount', 0) + 1 ||
              request.resource.data.acrosticCount == resource.data.get('acrosticCount', 0) - 1
            ))
          ||
          (changed.hasOnly(['viewCount'])
            && request.resource.data.viewCount == resource.data.get('viewCount', 0) + 1)
        );
    }

    function isSafeVoteUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return signedIn()
        && changed.hasOnly(['options', 'votedBy'])
        && request.resource.data.votedBy is list
        && request.resource.data.votedBy.hasAll(resource.data.get('votedBy', []))
        && !(request.auth.uid in resource.data.get('votedBy', []))
        && request.resource.data.votedBy.hasAny([request.auth.uid])
        && request.resource.data.votedBy.size() == resource.data.get('votedBy', []).size() + 1;
    }
    function isSafeMultiVoteUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return signedIn()
        && resource.data.type == 'multi'
        && changed.hasOnly(['modules'])
        && request.resource.data.authorId == resource.data.authorId
        && request.resource.data.type == resource.data.type;
    }
    function isAuthorContentUpdate(authorId) {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return isAuthor(authorId)
        && request.resource.data.authorId == resource.data.authorId
        && !changed.hasAny(['authorId', 'authorName', 'authorPhoto', 'reactions', 'reactedWith', 'commentCount', 'acrosticCount', 'viewCount', 'votedBy']);
    }

    function isMultiItemReactionOrReplyCountUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return signedIn()
        && (
          changed.hasOnly(['reactions'])
          || (changed.hasOnly(['replyCount'])
            && request.resource.data.replyCount == resource.data.get('replyCount', 0) + 1)
        );
    }

    function validReplyCreate() {
      return signedIn()
        && request.resource.data.authorId == request.auth.uid
        && validText(request.resource.data.text, 300);
    }
    function validMultiParticipationCreate() {
      return signedIn()
        && request.resource.data.authorId == request.auth.uid
        && validText(request.resource.data.get('text', ''), 500);
    }
    function validPointLogCreate(userId) {
      return isAuthor(userId)
        && request.resource.data.points is int
        && request.resource.data.points >= -100
        && request.resource.data.points <= 100
        && validText(request.resource.data.get('action', ''), 60)
        && validText(request.resource.data.get('label', ''), 80);
    }

    match /admins/{uid} {
      allow read:  if signedIn() && request.auth.uid == uid;
      allow write: if false;
    }

    match /site_settings/{docId}  { allow read: if true; allow write: if isAdmin(); }
    match /policy_docs/{docId}    { allow read: if true; allow write: if isAdmin(); }
    match /admin_summaries/{docId} { allow read: if isAdmin(); allow write: if false; }
    match /ai_usage/{docId}        { allow read: if isAdmin(); allow write: if false; }

    match /users/{userId} {
      allow read:   if isAuthor(userId) || isAdmin();
      allow create: if isAuthor(userId)
                      && validNickname(request.resource.data.get('nickname', ''));
      allow update: if isAuthor(userId) || isAdmin();
      allow delete: if isAdmin();

      match /point_logs/{logId} {
        allow read: if isAuthor(userId) || isAdmin();
        allow create: if validPointLogCreate(userId);
        allow update, delete: if false;
      }
    }

    match /nicknames/{nickname} {
      allow read:   if signedIn();
      allow create: if signedIn()
                      && validNickname(nickname)
                      && request.resource.data.uid == request.auth.uid
                      && !exists(/databases/$(database)/documents/nicknames/$(nickname));
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    match /feeds/{postId} {
      allow read:   if true;
      allow create: if signedIn()
                      && request.resource.data.authorId == request.auth.uid
                      && validText(request.resource.data.title, 100)
                      && validText(request.resource.data.get('desc', ''), 2000)
                      && validImageList();
      allow update: if isAdmin() || isAuthorContentUpdate(resource.data.authorId)
                      || isSafeCounterUpdate()
                      || isSafeVoteUpdate()
                      || isSafeMultiVoteUpdate();
      allow delete: if isAdmin() || isAuthor(resource.data.authorId);

      match /quiz_attempts/{userId} {
        allow read: if true;
        allow create, update, delete: if false;
      }

      match /comments/{commentId} {
        allow read:   if true;
        allow create: if signedIn()
                        && request.resource.data.authorId == request.auth.uid
                        && validText(request.resource.data.text, 500);
        allow update: if isAdmin() || isAuthorContentUpdate(resource.data.authorId);
        allow delete: if isAdmin() || isAuthor(resource.data.authorId);

        match /replies/{replyId} {
          allow read: if true;
          allow create: if validReplyCreate();
          allow update: if false;
          allow delete: if isAdmin() || isAuthor(resource.data.authorId);
        }
      }

      match /secret/{docId} {
        allow read:   if isAdmin();
        allow create: if isAdmin() ||
          (signedIn() &&
            get(/databases/$(database)/documents/feeds/$(postId)).data.authorId == request.auth.uid);
        allow update: if isAdmin();
        allow delete: if isAdmin();
      }

      match /acrostics/{acrosticId} {
        allow read:   if true;
        allow create: if signedIn()
                        && request.resource.data.authorId == request.auth.uid
                        && validText(request.resource.data.get('text', ''), 500);
        allow update: if isAdmin() || isAuthorContentUpdate(resource.data.authorId);
        allow delete: if isAdmin() || isAuthor(resource.data.authorId);

        match /replies/{replyId} {
          allow read: if true;
          allow create: if validReplyCreate();
          allow update: if false;
          allow delete: if isAdmin() || isAuthor(resource.data.authorId);
        }
      }

      match /multi_naming/{itemId} {
        allow read: if true;
        allow create: if validMultiParticipationCreate();
        allow update: if isAdmin() || isMultiItemReactionOrReplyCountUpdate();
        allow delete: if isAdmin() || isAuthor(resource.data.authorId);
        match /replies/{replyId} {
          allow read: if true;
          allow create: if validReplyCreate();
          allow update: if false;
          allow delete: if isAdmin() || isAuthor(resource.data.authorId);
        }
      }
      match /multi_acrostic/{itemId} {
        allow read: if true;
        allow create: if validMultiParticipationCreate();
        allow update: if isAdmin() || isMultiItemReactionOrReplyCountUpdate();
        allow delete: if isAdmin() || isAuthor(resource.data.authorId);
        match /replies/{replyId} {
          allow read: if true;
          allow create: if validReplyCreate();
          allow update: if false;
          allow delete: if isAdmin() || isAuthor(resource.data.authorId);
        }
      }
      match /multi_relay/{itemId} {
        allow read: if true;
        allow create: if validMultiParticipationCreate();
        allow update: if isAdmin() || isMultiItemReactionOrReplyCountUpdate();
        allow delete: if isAdmin() || isAuthor(resource.data.authorId);
        match /replies/{replyId} {
          allow read: if true;
          allow create: if validReplyCreate();
          allow update: if false;
          allow delete: if isAdmin() || isAuthor(resource.data.authorId);
        }
      }
      match /multi_fill/{itemId} {
        allow read: if true;
        allow create: if validMultiParticipationCreate();
        allow update: if isAdmin() || isMultiItemReactionOrReplyCountUpdate();
        allow delete: if isAdmin() || isAuthor(resource.data.authorId);
        match /replies/{replyId} {
          allow read: if true;
          allow create: if validReplyCreate();
          allow update: if false;
          allow delete: if isAdmin() || isAuthor(resource.data.authorId);
        }
      }

      match /viewers/{userId} {
        allow read, write: if false;
      }

      match /view_events/{eventId} {
        allow read, write: if false;
      }
    }

    match /game_rooms/{roomId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.hostId == request.auth.uid
        && request.resource.data.game == 'liar'
        && validText(request.resource.data.title, 60);
      allow update: if signedIn()
        && (resource.data.hostId == request.auth.uid || isAdmin());
      allow delete: if signedIn()
        && (resource.data.hostId == request.auth.uid || isAdmin());

      match /players/{userId} {
        allow read: if true;
        allow create, update: if isAuthor(userId)
          && request.resource.data.uid == request.auth.uid
          && validText(request.resource.data.name, 30);
        allow delete: if isAuthor(userId) || isAdmin();
      }
    }

    match /missions/{missionId} {
      allow read:   if true;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /reports/{reportId} {
      allow create: if signedIn()
                      && request.resource.data.reporterId == request.auth.uid
                      && validText(request.resource.data.get('reason', ''), 300);
      allow read, update, delete: if isAdmin();
    }

    match /users/{userId}/scraps/{scrapId} {
      allow read, write: if isAuthor(userId);
    }

    match /notifications/{notifId} {
      allow read:   if (signedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if (signedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow delete: if (signedIn() && resource.data.userId == request.auth.uid) || isAdmin();
    }

    match /soso_feed_posts/{postId} {
      allow read:  if true;
      allow write: if isAdmin();
      match /comments/{commentId} { allow read: if true; allow write: if isAdmin(); }
    }

    match /categories/{id}     { allow read, write: if isAdmin(); }
    match /system_jobs/{id}    { allow read, write: if isAdmin(); }
    match /usage_stats/{id}    { allow read: if isAdmin(); allow write: if false; }
    match /rate_limits/{id}    { allow read, write: if false; }
    match /feedback/{id}       { allow create: if signedIn(); allow read, update, delete: if isAdmin(); }

    match /config/{docId} {
      allow read:  if isAdmin();
      allow write: if false;
    }
    match /ai_reports/{docId} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    match /follows/{followId} {
      allow read:   if signedIn();
      allow create: if signedIn()
                      && request.resource.data.followerId == request.auth.uid
                      && request.resource.data.followedId is string
                      && request.resource.data.followedId != request.auth.uid;
      allow delete: if signedIn() && resource.data.followerId == request.auth.uid;
      allow update: if false;
    }
  }
}