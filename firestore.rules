rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /topics/{topicId} {
      allow read: if resource.data.status == 'active' || isAdmin();
      allow create: if false; // Cloud Function을 통해서만 생성
      allow update, delete: if isAdmin();
    }

    match /debate_sessions/{sessionId} {
      allow read: if request.auth != null && (
        resource.data.plaintiff.userId == request.auth.uid ||
        resource.data.defendant.userId == request.auth.uid ||
        isAdmin()
      );
      allow read: if request.auth != null && resource.data.status == 'waiting';
      allow create: if false;
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /random_queue/{topicId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /cases/{caseId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || resource.data.isPublic == true);
      allow read: if isAdmin();
      allow create: if request.auth != null;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /results/{caseId} {
      allow read: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if isAdmin();
      allow create: if false;
    }

    match /usage_stats/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /rate_limits/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /reports/{reportId} {
      allow create: if request.auth != null;
      allow read, update, delete: if isAdmin();
    }

    match /site_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /policy_docs/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
