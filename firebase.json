{
  "hosting": {
    "public": ".",
    "ignore": ["firebase.json", ".firebaserc", "README.md", "**/.*", "**/node_modules/**"],
    "rewrites": [{ "source": "**", "destination": "/index.html" }],
    "headers": [{ "source": "**/*.@(js|css)", "headers": [{ "key": "Cache-Control", "value": "public,max-age=3600" }] }]
  }
}