{
  "hosting": {
    "public": "public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "headers": [
      {
        "source": "/index.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, max-age=0, must-revalidate"
          }
        ]
      },
      {
        "source": "/admin/index.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, max-age=0, must-revalidate"
          }
        ]
      },
      {
        "source": "**/*.{js,css,png,jpg,jpeg,webp,svg,ico,webmanifest}",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      }
    ],
    "rewrites": [
      { "source": "/admin", "destination": "/admin/index.html" },
      { "source": "/admin/", "destination": "/admin/index.html" },
      { "source": "/board", "destination": "/index.html" },
      { "source": "/submit", "destination": "/index.html" },
      { "source": "/guide", "destination": "/index.html" },
      { "source": "/auth", "destination": "/index.html" },
      { "source": "/my-cases", "destination": "/index.html" },
      { "source": "/absurd-cases", "destination": "/index.html" },
      { "source": "/result/**", "destination": "/index.html" },
      { "source": "/trial/**", "destination": "/index.html" }
    ]
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  }
}
